# URL do evento na Sympla
EVENT_URL=https://www.sympla.com.br/evento/dubdogz-na-copa-um-presente-a-jf/3476107

# Token do bot do Telegram (obter em @BotFather)
BOT_TOKEN=seu_token_aqui

# ID do chat/grupo para enviar notificacoes
CHAT_ID=seu_chat_id_aqui

# Executar navegador em modo headless
HEADLESS=true

# Intervalo entre verificacoes em segundos (multiplo de 60)
CHECK_INTERVAL=60

# Hora de inicio do monitoramento (0-23)
START_HOUR=5

# Hora de fim do monitoramento (0-23)
END_HOUR=23

# Fuso horario
TIMEZONE=America/Sao_Paulo
